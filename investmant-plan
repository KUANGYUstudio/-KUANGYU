<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f13; color: #e8e4dc; min-height: 100vh; }
  button { cursor: pointer; font-family: inherit; }

  .header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    padding: 48px 24px 32px; text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .header-sub { font-size: 0.72rem; letter-spacing: 0.3em; color: #94a3b8; margin-bottom: 12px; text-transform: uppercase; }
  .header h1 { font-size: 1.8rem; font-weight: 700; color: #f1f5f9; margin-bottom: 8px; }
  .header p { color: #64748b; font-size: 0.88rem; }
  .stats { display: flex; justify-content: center; gap: 28px; margin-top: 28px; flex-wrap: wrap; }
  .stat-val { font-size: 1.3rem; font-weight: 700; color: #93c5fd; }
  .stat-label { font-size: 0.7rem; color: #64748b; margin-top: 2px; }

  .tabs { display: flex; justify-content: center; gap: 6px; padding: 20px 16px 0; flex-wrap: wrap; }
  .tab {
    padding: 9px 16px; border-radius: 99px; border: 1px solid rgba(255,255,255,0.1);
    background: transparent; color: #94a3b8; font-size: 0.82rem; white-space: nowrap; transition: all 0.2s;
  }
  .tab.active { background: #2563eb; border-color: #2563eb; color: white; }

  .content { max-width: 800px; margin: 0 auto; padding: 24px; }
  .panel { display: none; }
  .panel.active { display: block; }

  .card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px; padding: 22px; margin-bottom: 16px;
  }
  .card-accent-blue { border-left: 4px solid #2563eb; border-color: rgba(37,99,235,0.3); }
  .card-accent-green { border-left: 4px solid #059669; border-color: rgba(5,150,105,0.3); }
  .card-accent-purple { border-left: 4px solid #7c3aed; border-color: rgba(124,58,237,0.3); }

  .bucket-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; margin-bottom: 14px; }
  .bucket-title { font-size: 1.05rem; font-weight: 700; color: #f1f5f9; margin-bottom: 4px; }
  .bucket-desc { font-size: 0.8rem; color: #64748b; }
  .bucket-pct { font-size: 1.8rem; font-weight: 700; }
  .bucket-amt { font-size: 0.75rem; color: #64748b; }

  .bar-bg { background: rgba(255,255,255,0.06); border-radius: 99px; height: 6px; margin-bottom: 12px; }
  .bar-fill { height: 100%; border-radius: 99px; }

  .tags { display: flex; gap: 7px; flex-wrap: wrap; }
  .tag { border-radius: 8px; padding: 6px 12px; font-size: 0.78rem; }

  /* ETF cards */
  .etf-card { display: flex; gap: 16px; align-items: flex-start; flex-wrap: wrap; }
  .etf-badge { border-radius: 10px; padding: 10px 14px; text-align: center; min-width: 80px; }
  .etf-code { font-size: 1rem; font-weight: 700; }
  .etf-bucket { font-size: 0.68rem; color: #64748b; margin-top: 2px; }
  .etf-region { font-size: 0.72rem; margin-top: 4px; }
  .etf-name { font-size: 0.95rem; font-weight: 600; color: #f1f5f9; margin-bottom: 5px; }
  .etf-tip { font-size: 0.8rem; color: #94a3b8; line-height: 1.6; margin-bottom: 10px; }
  .pills { display: flex; gap: 7px; flex-wrap: wrap; }
  .pill { font-size: 0.72rem; background: rgba(255,255,255,0.06); padding: 3px 10px; border-radius: 99px; color: #64748b; }

  /* Calendar */
  .cal { display: grid; grid-template-columns: repeat(12, 1fr); gap: 5px; margin-bottom: 12px; }
  .cal-cell { border-radius: 7px; padding: 7px 3px; text-align: center; border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.03); }
  .cal-cell.has-income { background: rgba(5,150,105,0.12); border-color: rgba(5,150,105,0.25); }
  .cal-cell.full { background: rgba(37,99,235,0.1); border-color: rgba(37,99,235,0.2); }
  .cal-month { font-size: 0.65rem; color: #64748b; margin-bottom: 3px; }
  .cal-code { font-size: 0.52rem; font-weight: 700; line-height: 1.5; }
  .cal-empty { font-size: 0.6rem; color: #2d3748; }

  /* Schedule */
  .phase-badge { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 3px 10px; border-radius: 99px; margin-bottom: 6px; }
  .phase-title { font-size: 1rem; font-weight: 600; color: #f1f5f9; margin-bottom: 4px; }
  .phase-desc { font-size: 0.8rem; color: #64748b; margin-bottom: 14px; }
  .steps { display: grid; gap: 9px; }
  .step { display: flex; gap: 10px; align-items: flex-start; }
  .step-num { width: 20px; height: 20px; border-radius: 50%; font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .step-text { font-size: 0.85rem; color: #94a3b8; line-height: 1.6; padding-top: 1px; }

  /* Monthly breakdown */
  .monthly-row { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .monthly-left { display: flex; align-items: center; gap: 10px; }
  .monthly-dot { width: 7px; height: 7px; border-radius: 50%; }
  .monthly-code { font-weight: 600; font-size: 0.85rem; }
  .monthly-name { color: #64748b; font-size: 0.8rem; }
  .monthly-amt { font-weight: 700; color: #f1f5f9; font-size: 0.85rem; }

  /* Rules */
  .rules-grid { display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); }
  .rule-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 18px; display: flex; gap: 12px; }
  .rule-icon { font-size: 1.5rem; flex-shrink: 0; }
  .rule-title { font-weight: 700; color: #f1f5f9; margin-bottom: 5px; }
  .rule-desc { font-size: 0.82rem; color: #64748b; line-height: 1.6; }
  .formula-card {
    background: linear-gradient(135deg, rgba(37,99,235,0.1), rgba(124,58,237,0.1));
    border: 1px solid rgba(37,99,235,0.3); border-radius: 12px; padding: 20px 24px; text-align: center;
  }
  .formula-title { font-size: 1.05rem; color: #93c5fd; font-weight: 700; margin-bottom: 8px; }
  .formula-text { color: #94a3b8; font-size: 0.88rem; line-height: 1.8; }

  .footer { text-align: center; margin-top: 28px; font-size: 0.72rem; color: #334155; line-height: 1.6; }

  /* Donut */
  .donut-wrap { display: flex; align-items: center; justify-content: center; gap: 32px; flex-wrap: wrap; padding: 8px 0; }
  .legend { display: flex; flex-direction: column; gap: 10px; }
  .legend-item { display: flex; align-items: center; gap: 10px; }
  .legend-dot { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }
  .legend-name { font-size: 0.85rem; color: #94a3b8; }
  .legend-pct { font-weight: 700; margin-left: auto; padding-left: 16px; }
  .legend-note { border-top: 1px solid rgba(255,255,255,0.08); padding-top: 10px; font-size: 0.78rem; color: #64748b; }

  .section-title { font-size: 0.85rem; font-weight: 600; color: #94a3b8; margin-bottom: 14px; letter-spacing: 0.05em; }
  .tip-note { font-size: 0.78rem; color: #64748b; margin-top: 10px; }

  .future-item { display: flex; align-items: center; gap: 12px; border-radius: 8px; padding: 10px 14px; margin-top: 8px; }
  .future-badge { font-size: 0.7rem; font-weight: 700; padding: 2px 8px; border-radius: 99px; white-space: nowrap; }
  .future-code { font-weight: 700; font-size: 0.88rem; }
  .future-name { font-size: 0.82rem; color: #94a3b8; margin-left: 8px; }
  .future-month { font-size: 0.78rem; color: #64748b; margin-left: 8px; }
</style>
</head>
