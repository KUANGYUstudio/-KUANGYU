<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>穩健投資計畫 2.0</title>
<style>
  :root {
    --bg-main: #0a0a0f;
    --card-bg: rgba(255, 255, 255, 0.04);
    --border-color: rgba(255, 255, 255, 0.1);
    --accent-blue: #3b82f6;
    --accent-green: #10b981;
    --accent-purple: #8b5cf6;
    --text-primary: #f8fafc;
    --text-secondary: #94a3b8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { 
    font-family: "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif; 
    background: var(--bg-main); 
    color: var(--text-primary); 
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  .header {
    background: radial-gradient(circle at top right, #1e293b, #0f172a);
    padding: 60px 24px 40px;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
  }
  .header-sub { 
    font-size: 0.75rem; 
    letter-spacing: 0.4em; 
    color: var(--accent-blue); 
    margin-bottom: 16px; 
    font-weight: 600;
  }
  .header h1 { font-size: 2.2rem; margin-bottom: 12px; letter-spacing: -0.02em; }
  .header p { color: var(--text-secondary); font-size: 0.95rem; }

  .stats { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 20px; 
    max-width: 900px; 
    margin: 32px auto 0;
  }
  .stat-item {
    background: var(--card-bg);
    padding: 16px;
    border-radius: 16px;
    border: 1px solid var(--border-color);
  }
  .stat-val { font-size: 1.4rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
  .stat-label { font-size: 0.75rem; color: var(--text-secondary); }

  .tabs { 
    display: flex; 
    justify-content: center; 
    gap: 8px; 
    padding: 24px 16px; 
    position: sticky; 
    top: 0; 
    z-index: 100;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
  }
  .tab {
    padding: 10px 20px; 
    border-radius: 12px; 
    border: 1px solid var(--border-color);
    background: transparent; 
    color: var(--text-secondary); 
    font-size: 0.88rem; 
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .tab.active { 
    background: var(--accent-blue); 
    border-color: var(--accent-blue); 
    color: white;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
  }

  .content { max-width: 860px; margin: 0 auto; padding: 0 24px 80px; }
  .panel { display: none; animation: fadeIn 0.4s ease-out; }
  .panel.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card {
    background: var(--card-bg); 
    border: 1px solid var(--border-color);
    border-radius: 20px; 
    padding: 28px; 
    margin-bottom: 20px;
    transition: transform 0.3s ease, background 0.3s ease;
  }
  .card:hover { 
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-2px);
  }

  /* 桶位顏色裝飾 */
  .card-accent-blue { border-top: 4px solid var(--accent-blue); }
  .card-accent-green { border-top: 4px solid var(--accent-green); }
  .card-accent-purple { border-top: 4px solid var(--accent-purple); }

  .bucket-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; }
  .bucket-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 4px; }
  .bucket-pct { font-size: 2rem; font-weight: 800; line-height: 1; }

  .bar-bg { background: rgba(255,255,255,0.08); border-radius: 99px; height: 8px; margin-bottom: 20px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 99px; transition: width 1s ease-in-out; }

  .tag-group { display: flex; gap: 10px; flex-wrap: wrap; }
  .tag { 
    background: rgba(255, 255, 255, 0.05); 
    border: 1px solid var(--border-color);
    border-radius: 10px; 
    padding: 8px 14px; 
    font-size: 0.85rem;
  }

  /* ETF 明細優化 */
  .etf-grid { display: flex; align-items: center; gap: 24px; }
  .etf-info-main { flex: 1; }
  .etf-code-box { 
    background: var(--bg-main); 
    padding: 12px; 
    border-radius: 14px; 
    text-align: center; 
    min-width: 100px;
  }
  .etf-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: #fff; }
  .etf-desc { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 16px; }

  /* 日曆優化 */
  .cal-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(60px, 1fr)); gap: 8px; }
  .cal-box { 
    background: rgba(255,255,255,0.03); 
    border: 1px solid var(--border-color);
    border-radius: 12px; 
    padding: 12px 4px; 
    text-align: center;
  }
  .cal-box.active { background: rgba(59, 130, 246, 0.1); border-color: rgba(59, 130, 246, 0.4); }
  .cal-m { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 4px; }
  .cal-c { font-size: 0.7rem; font-weight: 700; color: var(--accent-blue); }

  /* 規則列表 */
  .rule-list { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 600px) { .rule-list { grid-template-columns: 1fr; } }
  .rule-item { 
    padding: 20px; 
    background: var(--card-bg); 
    border-radius: 16px;
    border: 1px solid var(--border-color);
  }
  .rule-item h4 { margin-bottom: 8px; color: var(--accent-blue); }

  .footer { text-align: center; padding: 40px; color: #475569; font-size: 0.8rem; }

  /* 圖表佔位 */
  .chart-container { display: flex; justify-content: center; padding: 20px 0; }

</style>
</head>
<body>

<header class="header">
  <div class="header-sub">CORE INVESTMENT STRATEGY</div>
  <h1>50萬長期投資計畫</h1>
  <p>配置對策：三桶架構 × 定期定額 × 跨國配置</p>
  
  <div class="stats">
    <div class="stat-item">
      <div class="stat-val">50萬</div>
      <div class="stat-label">首批投入</div>
    </div>
    <div class="stat-item">
      <div class="stat-val">4.0萬</div>
      <div class="stat-label">每月定額</div>
    </div>
    <div class="stat-item">
      <div class="stat-val">10年</div>
      <div class="stat-label">計畫週期</div>
    </div>
    <div class="stat-item">
      <div class="stat-val">5檔</div>
      <div class="stat-label">組合核心</div>
    </div>
  </div>
</header>

<nav class="tabs">
  <button class="tab active" onclick="switchTab(event, 'overview')">資產配置</button>
  <button class="tab" onclick="switchTab(event, 'details')">標的明細</button>
  <button class="tab" onclick="switchTab(event, 'plan')">執行時程</button>
  <button class="tab" onclick="switchTab(event, 'rules')">投資守則</button>
</nav>

<main class="content">
  <!-- 頁籤 1: 資產配置 -->
  <section id="overview" class="panel active">
    <div class="card card-accent-blue">
      <div class="bucket-header">
        <div>
          <div class="bucket-title">成長桶</div>
          <p class="etf-desc">追求長期資產最大增值</p>
        </div>
        <div style="text-align: right">
          <div class="bucket-pct" style="color: var(--accent-blue)">50%</div>
          <p class="stat-label">250,000 元</p>
        </div>
      </div>
      <div class="bar-bg"><div class="bar-fill" style="width: 50%; background: var(--accent-blue)"></div></div>
      <div class="tag-group">
        <div class="tag">006208 富邦台50 (25%)</div>
        <div class="tag">00646 元大S&P500 (25%)</div>
      </div>
    </div>

    <div class="card card-accent-green">
      <div class="bucket-header">
        <div>
          <div class="bucket-title">收息桶</div>
          <p class="etf-desc">建立穩定且可預期的現金流</p>
        </div>
        <div style="text-align: right">
          <div class="bucket-pct" style="color: var(--accent-green)">30%</div>
          <p class="stat-label">150,000 元</p>
        </div>
      </div>
      <div class="bar-bg"><div class="bar-fill" style="width: 30%; background: var(--accent-green)"></div></div>
      <div class="tag-group">
        <div class="tag">00878 國泰永續高股息 (15%)</div>
        <div class="tag">00713 元大高息低波 (15%)</div>
      </div>
    </div>

    <div class="card card-accent-purple">
      <div class="bucket-header">
        <div>
          <div class="bucket-title">保護桶</div>
          <p class="etf-desc">降低整體波動與避險工具</p>
        </div>
        <div style="text-align: right">
          <div class="bucket-pct" style="color: var(--accent-purple)">20%</div>
          <p class="stat-label">100,000 元</p>
        </div>
      </div>
      <div class="bar-bg"><div class="bar-fill" style="width: 20%; background: var(--accent-purple)"></div></div>
      <div class="tag-group">
        <div class="tag">00679B 元大美債20年 (20%)</div>
      </div>
    </div>
  </section>

  <!-- 頁籤 2: 標的明細 -->
  <section id="details" class="panel">
    <div class="card">
      <div class="etf-grid">
        <div class="etf-code-box">
          <div style="font-weight: 800; color: var(--accent-blue)">006208</div>
          <div style="font-size: 0.7rem; color: var(--text-secondary)">台灣</div>
        </div>
        <div class="etf-info-main">
          <div class="etf-name">富邦台灣採樣母體</div>
          <p class="etf-desc">投資台灣市值前50大公司。內扣費用極低，是參與台灣經濟成長的首選。</p>
          <div class="tag-group">
            <span class="tag">配置 10,000/月</span>
            <span class="tag">半年配息</span>
          </div>
        </div>
      </div>
    </div>
    <!-- 其他標的可依此類推複製 -->
  </section>

  <!-- 頁籤 3: 執行時程 -->
  <section id="plan" class="panel">
    <div class="card">
      <h3 style="margin-bottom: 20px">年度配息日曆</h3>
      <div class="cal-grid" id="dividend-cal">
        <!-- JS 將生成內容 -->
      </div>
    </div>
  </section>

  <!-- 頁籤 4: 投資守則 -->
  <section id="rules" class="panel">
    <div class="rule-list">
      <div class="rule-item">
        <h4>紀律投入</h4>
        <p class="etf-desc">忽略市場漲跌，每月固定日期扣款，讓持有成本平滑化。</p>
      </div>
      <div class="rule-item">
        <h4>股息再投入</h4>
        <p class="etf-desc">初期領到的配息不應提領，應自動買回原標的，啟動複利加速器。</p>
      </div>
      <div class="rule-item">
        <h4>風險耐受</h4>
        <p class="etf-desc">如遇市場下跌 20% 以上，嚴禁情緒性停損，應視為獲取廉價部位的機會。</p>
      </div>
      <div class="rule-item">
        <h4>十年週期</h4>
        <p class="etf-desc">此計畫非短期獲利，目標為十年後資產的穩健翻倍與現金流替代。</p>
      </div>
    </div>
  </section>
</main>

<footer class="footer">
  本文僅供學習紀錄，非投資建議。市場有風險，投入前請審慎評估。
</footer>

<script>
  function switchTab(event, tabId) {
    // 移除所有 active 狀態
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    
    // 加入當前 active 狀態
    event.currentTarget.classList.add('active');
    document.getElementById(tabId).classList.add('active');
    
    // 平滑捲動回頂部
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // 初始化模擬日曆
  const calGrid = document.getElementById('dividend-cal');
  for (let i = 1; i <= 12; i++) {
    const div = document.createElement('div');
    div.className = 'cal-box' + ([2, 5, 8, 11].includes(i) ? ' active' : '');
    div.innerHTML = `<div class="cal-m">${i}月</div><div class="cal-c">${[2, 5, 8, 11].includes(i) ? '配息月' : '-'}</div>`;
    calGrid.appendChild(div);
  }
</script>
</body>
</html>
